rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow all authenticated users (including anonymous ones) to read and write
    // This supports the standalone password gate on the dashboard
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }
    
    match /attendance/{logId} {
      allow read, write: if request.auth != null;
    }

    match /projects/{projectId} {
      allow read, write: if request.auth != null;
    }

    match /ouvrages/{ouvrageId} {
      allow read, write: if request.auth != null;
    }
  }
}
